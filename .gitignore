dist-newstyle/
dist/
.ghc.environment.*
*.hi
*.hi-boot
*.o
*.o-boot
*.dyn_hi
*.dyn_o
*.p_o
*.chi
*.prof
*.hp
*.aux

# Clash HDL output (created during the build cycle)
hdl/verilog/
hdl/vhdl/
hdl/systemverilog/

