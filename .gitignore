*.jou
*.log
*.str
*.dcp
*.bit
*.ltx
*.backup.*
.Xil/
.cache/
usage_statistics_webtalk.*
vivado_pid*.str

# Local, machine-specific tool-path overrides (build.cfg.local etc.)
*.local

